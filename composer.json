{
	"name": "beapi/virtual-llms-txt",
	"description": "Serves a virtual llms.txt document from site settings (plain text, per site).",
	"license": "GPL-2.0-or-later",
	"type": "wordpress-plugin",
	"keywords": [
		"wordpress",
		"llms.txt",
		"llmstxt"
	],
	"authors": [
		{
			"name": "Be API",
			"email": "technique@beapi.fr",
			"homepage": "https://beapi.fr"
		}
	],
	"homepage": "https://github.com/BeAPI/virtual-llms-txt",
	"require": {
		"php": ">=8.0.0",
		"composer/installers": "^1.0 || ^2.0"
	},
	"require-dev": {
		"dealerdirect/phpcodesniffer-composer-installer": "^1.0",
		"phpcompatibility/php-compatibility": "^9.3",
		"squizlabs/php_codesniffer": "^3.10",
		"wp-coding-standards/wpcs": "^3.3"
	},
	"minimum-stability": "stable",
	"config": {
		"allow-plugins": {
			"composer/installers": true,
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	},
	"scripts": {
		"cbf": "./vendor/bin/phpcbf",
		"cs": "./vendor/bin/phpcs"
	}
}
